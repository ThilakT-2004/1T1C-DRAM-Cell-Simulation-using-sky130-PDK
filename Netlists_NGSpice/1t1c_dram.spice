**.subckt 1t1c_dram bl cs wl vdd blb
*.ipin bl
*.ipin cs
*.ipin wl
*.ipin vdd
*.ipin blb
XM1 bl cs wl gnd sky130_fd_pr__nfet_01v8 L=0.15 W=1 nf=1 ad=0.29 as=0.29 pd=2.58 ps=2.58 nrd=0.29 nrs=0.29 sa=0 sb=0 sd=0 mult=1
C1 bl gnd 200f
C2 wl gnd 200f
C3 cs gnd 30f
XM2 cs blb vdd vdd sky130_fd_pr__pfet_01v8 L=0.15 W=1.5 nf=1 ad=0.435 as=0.435 pd=3.58 ps=3.58 nrd=0.193333333333333
+ nrs=0.193333333333333 sa=0 sb=0 sd=0 mult=1
